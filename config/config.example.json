{
  "version": 1,
  "defaultProvider": "agnes",
  "defaultRegion": "cn",

  "providers": {
    "agnes": {
      "baseUrl": "https://apihub.agnes-ai.com/v1",
      "defaultModel": "agnes-image-2.1-flash",
      "timeout": 30000,
      "maxRetries": 3
    },
    "apimart": {
      "baseUrl": "https://api.apimart.ai/v1",
      "defaultModel": "gpt-image-2"
    },
    "tuzi": {
      "baseUrl": "https://api.tu-zi.com/v1",
      "defaultModel": "gpt-image-2"
    },
    "minimax": {
      "baseUrl": "https://api.minimax.io/v1",
      "defaultModel": "MiniMax-M2.7"
    },
    "mimo": {
      "baseUrl": "https://api.xiaomimimo.com/v1",
      "defaultModel": "mimo-v2.5-tts"
    }
  },

  "imagine": {
    "defaultProvider": "agnes",
    "defaultModel": "agnes-image-2.1-flash",
    "defaultQuality": "2k",
    "defaultAspectRatio": "1:1"
  },

  "tts": {
    "defaultProvider": "minimax",
    "defaultModel": "speech-2.8-hd",
    "defaultVoice": "female-shaonv",
    "defaultFormat": "mp3",
    "defaultSpeed": 1.0,
    "defaultVol": 3,
    "defaultPitch": 0
  },

  "video": {
    "defaultProvider": "apimart",
    "defaultModel": "doubao-seedance-1-0-pro-fast",
    "defaultSeconds": 5,
    "defaultResolution": "1080p",
    "pollInterval": 5000,
    "batchPollInterval": 10000,
    "timeout": 600000,
    "batchTimeout": 3600000
  },

  "bgm": {
    "defaultProvider": "minimax",
    "defaultModel": "music-2.6"
  },

  "picgo": {
    "repo": "username/image-host",
    "branch": "main",
    "path": "assets/images",
    "customUrl": "https://cdn.jsdmirror.com/gh/username/image-host@main"
  },

  "display": {
    "defaultFormat": "text",
    "quiet": false,
    "noColor": false
  },

  "proxy": ""
}
